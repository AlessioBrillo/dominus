# DOMINUS environment configuration
# Copy to .env and fill in values.

# SQLite database path (default: ./data/dominus.db)
DATABASE_PATH=./data/dominus.db

# Port for the dev server (default: 3000)
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: path to Google Keyword Planner JSON export.
# Format: [{ "term": "cloud", "monthlySearchVolume": 12000, "cpc": 4.5, "competition": 0.7 }, …]
# When absent, all keyword lookups return zero volume (intrinsic signal only).
# KEYWORD_DATA_PATH=./data/keywords.json

# Keyword provider implementation (default: manual).
# KEYWORD_PROVIDER=manual

# Optional: path to NameBio comparable sales CSV export.
# Columns: domain,price,date,venue  (header row required)
# When absent, no comparable sales are used in scoring.
# COMPS_DATA_PATH=./data/comps.csv

# Comparable-sales provider implementation (default: manual).
# COMPS_PROVIDER=manual

# --- Trademark providers ---

# USPTO public search URL (no API key required; default is the official endpoint).
# USPTO_SEARCH_URL=https://tmsearch.uspto.gov/search/search-information

# EUIPO Trademark Search 1.1.0 (RSQL-based, OAuth2 client_credentials).
# Register at: https://euipo.europa.eu/ohimportal/en/open-data
# The same client_id is sent as `X-IBM-Client-Id` on every search request.
# When absent, EUIPO is skipped and the gate degrades gracefully to USPTO-only.
# EUIPO_CLIENT_ID=your-client-id
# EUIPO_CLIENT_SECRET=your-client-secret
# EUIPO_AUTH_URL=https://euipo.europa.eu/oauth2/token
# EUIPO_API_URL=https://api.euipo.europa.eu/trademark-search/trademarks

# Number of days a cached trademark result stays valid (default: 7).
# TM_CACHE_TTL_DAYS=7

# --- WHOIS port-43 provider ---
#
# Maximum milliseconds to wait for a WHOIS server response.
# Increase (e.g. 20000) for slow ccTLD servers; decrease (e.g. 5000) to fail fast.
# WHOIS_LOOKUP_TIMEOUT=10000

# --- Budget / Safety ---
#
# Absolute cap on 'suggested_buy_max' in EUR (default: 500).
# Prevents the scoring engine from recommending purchases beyond budget.
# BUY_MAX_ABSOLUTE_CAP=500

# Minimum weightedScore (0-1) for a candidate to be recommended (default: 0.4).
# Lowering this makes the engine more generous (more recommendations);
# raising it makes it more conservative. Must be lower than 1.0.
# SCORING_RECOMMEND_THRESHOLD=0.4

# --- Scoring signal calibration ---
#
# These parameters control the internal behaviour of each scoring signal.
# Defaults reflect the original conservative tuning; fork freely.
#
# SCORING_IDEAL_LENGTH=7            # Ideal SLD length (intrinsic signal)
# SCORING_MAX_LENGTH=20             # Max SLD length before score = 0
# SCORING_MAX_VOLUME=1000000        # Max monthly search volume ceiling
# SCORING_MAX_CPC=50                # Max CPC ceiling
# SCORING_FLOOR_VALUE=500           # Floor market value in EUR
# SCORING_HIGH_VALUE=10000          # High market value in EUR
# SCORING_MAX_AGE_YEARS=20          # Max domain age for expiry signal
# SCORING_MAX_BACKLINKS=1000        # Max backlinks for expiry signal
# SCORING_MAX_WAYBACK=500           # Max Wayback snapshots for expiry signal
# SCORING_BUY_MAX_RATIO=0.5         # suggestedBuyMax = expectedValue × this
# SCORING_LIST_PRICE_MULTIPLIER=2.5 # suggestedListPrice = expectedValue × this
# SCORING_BASE_MARKET_VALUE=500     # Base EUR value for expected value calc
# SCORING_CONFIDENCE_BASE=0.2       # Starting confidence with 1 signal
# SCORING_CONFIDENCE_PER_SIGNAL=0.3 # [DEPRECATED] No longer used — confidence is computed
#                                      via weight-covered-proportion formula instead.
#                                      Kept for backward compat; value is parsed but ignored.
# SCORING_CONFIDENCE_CAP=0.8        # Absolute confidence cap

# --- TLD bonus overrides ---
#
# Path to a JSON file mapping TLDs to multiplier bonuses.
# Merged with defaults (.com=1.0, .io=0.85, .ai=0.9, .co=0.75, .net=0.65, .org=0.55).
# Unknown TLDs fall back to 0.3.
# Format: { ".com": 1.0, ".xyz": 0.4 }
# TLD_BONUSES_PATH=./data/tld-bonuses.json

# --- Candidate generation ---
#
# Default TLD appended to bare keywords (default: .com).
# DEFAULT_KEYWORD_TLD=.com

# --- Trademark matching calibration ---
#
# TRADEMARK_MIN_TOKEN_LENGTH_FUZZY=4       # Min token length for Levenshtein matching
# TRADEMARK_MIN_MARK_TOKEN_LENGTH_SUBSTRING=3  # Min mark token length for substring
# TRADEMARK_MAX_LEVENSHTEIN=1              # Max edit distance for fuzzy matching

# --- Server ---
#
# Network interface to bind the Express server to (default: 127.0.0.1).
# HOST=127.0.0.1

# --- Renewal Monitoring & Notifications ---
#
# Thresholds for renewal alert generation (defaults: 30 warning, 7 critical).
# RENEWAL_WARNING_DAYS=30
# RENEWAL_CRITICAL_DAYS=7

# Enable desktop notifications via notify-send (Linux/BSD only).
# NOTIFIER_DESKTOP_ENABLED=false

# Generic webhook URL for alert forwarding (Slack, Discord, etc.).
# NOTIFIER_WEBHOOK_URL=https://hooks.example.com/alert

# Telegram bot integration. Create a bot via @BotFather to get a token.
# NOTIFIER_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# NOTIFIER_TELEGRAM_CHAT_ID=-1001234567890

# --- Scheduler (in-process cron) ---
#
# Enable when the API server runs as a long-lived process.
# For one-shot execution (crontab compatible), use:
#   dominus scheduler run <job>
# SCHEDULER_ENABLED=false
# SCHEDULER_RENEWAL_CHECK_CRON=0 8 * * *
# SCHEDULER_RESCORE_CRON=0 9 * * 1
# SCHEDULER_PRUNE_CRON=0 10 1 * *

# --- Auto Weight Tuning ---
#
# When enabled, the system periodically runs backtest → suggest → validate
# → apply cycle on scoring weights. Safety guardrails prevent runaway drift.
# Start with AUTO_TUNE_DRY_RUN=true to preview changes before live tuning.
# AUTO_TUNE_ENABLED=false
# AUTO_TUNE_WEIGHTS_PATH=./data/weights-override.json
# AUTO_TUNE_MIN_SAMPLE=20
# AUTO_TUNE_MAX_DELTA=0.05
# AUTO_TUNE_MAX_DRIFT=0.20
# AUTO_TUNE_DRY_RUN=true
# AUTO_TUNE_CRON=0 6 1 * *

# --- API Authentication ---
#
# Comma-separated API keys for REST API authentication.
# When empty or unset, authentication is disabled (not recommended for
# production deployments). Supports named keys with name=key format:
#   API_KEYS=sk-my-secret
#   API_KEYS=admin=sk-admin-key,readonly=sk-readonly-key
#
# Clients authenticate via Authorization: Bearer <key> header.
# The /api/health endpoint is always accessible without auth.
# API_KEYS=

# --- Cloudflare Registrar ---
#
# API token with Zone:Read, Registrar:Read, and Registrar:Write permissions.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=
#
# Cloudflare Account ID (found in the dashboard overview page).
# CLOUDFLARE_ACCOUNT_ID=
