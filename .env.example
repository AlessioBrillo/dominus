# DOMINUS environment configuration
# Copy to .env and fill in values.

# SQLite database path (default: ./data/dominus.db)
DATABASE_PATH=./data/dominus.db

# Port for the dev server (default: 3000)
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: path to Google Keyword Planner JSON export.
# Format: [{ "term": "cloud", "monthlySearchVolume": 12000, "cpc": 4.5, "competition": 0.7 }, …]
# When absent, all keyword lookups return zero volume (intrinsic signal only).
# KEYWORD_DATA_PATH=./data/keywords.json

# Optional: path to NameBio comparable sales CSV export.
# Columns: domain,price,date,venue  (header row required)
# When absent, no comparable sales are used in scoring.
# COMPS_DATA_PATH=./data/comps.csv

# --- Trademark providers ---

# USPTO public search URL (no API key required; default is the official endpoint).
# USPTO_SEARCH_URL=https://tmsearch.uspto.gov/search/search-information

# EUIPO Trademark Search 1.1.0 (RSQL-based, OAuth2 client_credentials).
# Register at: https://euipo.europa.eu/ohimportal/en/open-data
# The same client_id is sent as `X-IBM-Client-Id` on every search request.
# When absent, EUIPO is skipped and the gate degrades gracefully to USPTO-only.
# EUIPO_CLIENT_ID=your-client-id
# EUIPO_CLIENT_SECRET=your-client-secret
# EUIPO_AUTH_URL=https://euipo.europa.eu/oauth2/token
# EUIPO_API_URL=https://api.euipo.europa.eu/trademark-search/trademarks

# Number of days a cached trademark result stays valid (default: 7).
# TM_CACHE_TTL_DAYS=7
