# DOMINUS environment configuration
# Copy to .env and fill in values.
# Line numbering: 111 configurable parameters (Zod schema at src/config.ts).

# --- Core paths ---
# SQLite database path (community edition - default).
DATABASE_PATH=./data/dominus.db

# PostgreSQL connection string (DOMINUS Cloud edition).
# When set, overrides DATABASE_PATH and uses PostgreSQL instead of SQLite.
# Format: postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://dominus:password@localhost:5432/dominus

# SQLite busy timeout in ms (default: 30000 = 30s).
# Increase for bulk pipeline writes concurrent with API reads (ADR-0023).
# DATABASE_BUSY_TIMEOUT=30000

# Port for the API/Express server (default: 3000).
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Pretty-print logs (pino-pretty). Use for local dev; disable in production.
# LOG_PRETTY=true

# --- Provider rate limiting ---
#
# RDAP: token-bucket rate limiter (defaults: 10 tokens / 1000ms window).
# RDAP_RATE_LIMIT_TOKENS=10
# RDAP_RATE_LIMIT_INTERVAL_MS=1000
#
# WHOIS: token-bucket rate limiter (defaults: 5 tokens / 5000ms window).
# WHOIS_RATE_LIMIT_TOKENS=5
# WHOIS_RATE_LIMIT_INTERVAL_MS=5000
# WHOIS_RATE_LIMIT_OVERRIDES={"com":10,"org":10}
#
# DNS: bulk concurrency (default: 10).
# DNS_BULK_CONCURRENCY=10
# DNS: per-domain lookup timeout in ms (default: 3000).
# DNS_LOOKUP_TIMEOUT_MS=5000
# DNS: in-memory cache TTL in seconds (default: 300 = 5 min).
# DNS_CACHE_TTL_SECONDS=300
#
# Provider cache TTL (default: 1 day). Reduces repeated API calls.
# PROVIDER_CACHE_TTL_DAYS=1

# --- RDAP multi-server failover ---
#
# JSON array of RDAP bootstrap server base URLs for resilience.
# When the first server fails (timeout, network error), the next is tried.
# Default: rdap.org, Verisign COM RDAP, Google Registry RDAP.
# Example: RDAP_BOOTSTRAP_URLS=["https://rdap.org/domain/"]
# RDAP_BOOTSTRAP_URLS=

# Optional: path to Google Keyword Planner JSON export.
# Format: [{ "term": "cloud", "monthlySearchVolume": 12000, "cpc": 4.5, "competition": 0.7 }, …]
# When absent, all keyword lookups return zero volume (intrinsic signal only).
# KEYWORD_DATA_PATH=./data/keywords.json

# Keyword provider implementation (default: manual).
# Options: manual, google-ads
# KEYWORD_PROVIDER=manual

# Google Ads Keyword Planner API credentials (required when KEYWORD_PROVIDER=google-ads).
# Register at: https://console.cloud.google.com/apis/credentials (OAuth2 client)
# Developer token: https://developers.google.com/google-ads/api/docs/first-call/dev-token
# Free tier: 10,000 queries/day per developer token.
# GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_ADS_CLIENT_SECRET=your-client-secret
# GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
# GOOGLE_ADS_CUSTOMER_ID=1234567890

# Optional: path to NameBio comparable sales CSV export.
# Columns: domain,price,date,venue  (header row required)
# When absent, no comparable sales are used in scoring.
# COMPS_DATA_PATH=./data/comps.csv

# Comparable-sales provider implementation (default: manual).
# Options: manual, namebio
# COMPS_PROVIDER=manual

# API key for the NameBio API (namebio.com/api).
# Register at namebio.com/api to get a free API key.
# When absent, the NameBio provider gracefully returns zero results.
# NAMEBIO_API_KEY=your-namebio-api-key

# --- Trademark providers ---

# USPTO public search URL (no API key required; default is the official endpoint).
# USPTO_SEARCH_URL=https://tmsearch.uspto.gov/search/search-information

# EUIPO Trademark Search 1.1.0 (RSQL-based, OAuth2 client_credentials).
# Register at: https://euipo.europa.eu/ohimportal/en/open-data
# The same client_id is sent as `X-IBM-Client-Id` on every search request.
# When absent, EUIPO is skipped and the gate degrades gracefully to USPTO-only.
# EUIPO_CLIENT_ID=your-client-id
# EUIPO_CLIENT_SECRET=your-client-secret
# EUIPO_AUTH_URL=https://euipo.europa.eu/oauth2/token
# EUIPO_API_URL=https://api.euipo.europa.eu/trademark-search/trademarks

# Number of days a cached trademark result stays valid (default: 7).
# TM_CACHE_TTL_DAYS=7

# --- WHOIS port-43 provider ---
#
# Maximum milliseconds to wait for a WHOIS server response.
# Increase (e.g. 20000) for slow ccTLD servers; decrease (e.g. 5000) to fail fast.
# WHOIS_LOOKUP_TIMEOUT=10000

# --- Budget / Safety ---
#
# Absolute cap on 'suggested_buy_max' in EUR (default: 500).
# Prevents the scoring engine from recommending purchases beyond budget.
# BUY_MAX_ABSOLUTE_CAP=500

# Minimum weightedScore (0-1) for a candidate to be recommended (default: 0.4).
# Lowering this makes the engine more generous (more recommendations);
# raising it makes it more conservative. Must be lower than 1.0.
# SCORING_RECOMMEND_THRESHOLD=0.4

# Minimum confidence (0-1) for a buy recommendation (default: 0.3).
# Names below this threshold are blocked regardless of expected_value.
# SCORING_CONFIDENCE_THRESHOLD=0.3

# Number of years held in suggested_buy_max calculation (default: 3).
# Longer horizon = lower buy max due to cumulative renewal costs.
# SCORING_HOLDING_YEARS=3

# Fraction of confidence range influenced by intrinsic quality (default: 0.12).
# See ADR-0020 for the full formula.
# SCORING_INTRINSIC_QUALITY_INFLUENCE=0.12

# Path to a JSON file with manual weight overrides.
# Overrides both DEFAULT_WEIGHTS and auto-tuned weights.
# Format: { "intrinsic": 0.3, "commercial": 0.35, "market": 0.25, "expiry": 0.1 }
# SCORING_WEIGHTS_OVERRIDE=./data/weights-override.json

# --- Scoring signal calibration ---
#
# These parameters control the internal behaviour of each scoring signal.
# Defaults reflect the original conservative tuning; fork freely.
#
# SCORING_IDEAL_LENGTH=7            # Ideal SLD length (intrinsic signal)
# SCORING_MAX_LENGTH=20             # Max SLD length before score = 0
# SCORING_MAX_VOLUME=1000000        # Max monthly search volume ceiling
# SCORING_MAX_CPC=50                # Max CPC ceiling
# SCORING_FLOOR_VALUE=500           # Floor market value in EUR
# SCORING_HIGH_VALUE=10000          # High market value in EUR
# SCORING_MAX_AGE_YEARS=20          # Max domain age for expiry signal
# SCORING_MAX_BACKLINKS=1000        # Max backlinks for expiry signal
# SCORING_MAX_WAYBACK=500           # Max Wayback snapshots for expiry signal
# SCORING_BUY_MAX_RATIO=0.5         # suggestedBuyMax = expectedValue × this
# SCORING_LIST_PRICE_MULTIPLIER=2.5 # suggestedListPrice = expectedValue × this
# SCORING_BASE_MARKET_VALUE=500     # Base EUR value for expected value calc
# SCORING_CONFIDENCE_BASE=0.2       # Starting confidence with 1 signal
# SCORING_CONFIDENCE_PER_SIGNAL=0.3 # [DEPRECATED] No longer used — confidence is computed
#                                      via weight-covered-proportion formula instead.
#                                      Kept for backward compat; value is parsed but ignored.
# SCORING_CONFIDENCE_CAP=0.8        # Absolute confidence cap

# --- TLD bonus overrides ---
#
# Path to a JSON file mapping TLDs to multiplier bonuses.
# Merged with defaults (.com=1.0, .io=0.85, .ai=0.9, .co=0.75, .net=0.65, .org=0.55).
# Unknown TLDs fall back to 0.3.
# Format: { ".com": 1.0, ".xyz": 0.4 }
# TLD_BONUSES_PATH=./data/tld-bonuses.json

# --- Candidate generation ---
#
# Default TLD appended to bare keywords (default: .com).
# DEFAULT_KEYWORD_TLD=.com

# --- Trademark matching calibration ---
#
# TRADEMARK_MIN_TOKEN_LENGTH_FUZZY=4       # Min token length for Levenshtein matching
# TRADEMARK_MIN_MARK_TOKEN_LENGTH_SUBSTRING=3  # Min mark token length for substring
# TRADEMARK_MAX_LEVENSHTEIN=1              # Max edit distance for fuzzy matching

# --- Pipeline & Batch Config ---
#
# Per-pipeline-stage timeout in ms (default: 120000).
# PIPELINE_TIMEOUT_MS=120000
# Concurrency limits for batch operations (defaults: 5).
# RDAP_BATCH_CONCURRENCY=5
# TRADEMARK_BATCH_CONCURRENCY=5
# SCORING_BATCH_CONCURRENCY=5
# RESCORE_BATCH_CONCURRENCY=5

# --- API Server ---
#
# Network interface to bind the Express server to (default: 127.0.0.1).
# HOST=127.0.0.1
# Request timeout in ms (default: 30000).
# REQUEST_TIMEOUT_MS=30000
# CORS origin (default: http://localhost:5173 for Vite dev).
# CORS_ORIGIN=http://localhost:5173
# Rate limit window in ms (default: 900000 = 15 min).
# RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (default: 100).
# RATE_LIMIT_MAX=100

# --- Frontend SPA ---
#
# Path to the built frontend dist directory (default: ./frontend/dist).
# FRONTEND_DIST_PATH=./frontend/dist
# Base path for frontend API proxy (default: /api).
# FRONTEND_BASE_PATH=/api

# --- Drop Verdict Engine ---
#
# Score threshold for "threshold" drop method (default: 0.3).
# Domains below this score + renewal imminent = Drop recommendation.
# DROP_SCORE_THRESHOLD=0.3
# Renewal horizon days for drop verdict (default: 30).
# If renewal is within this window and score is low, recommend drop.
# DROP_RENEWAL_HORIZON_DAYS=30
# Drop method: threshold | npv (default: threshold).
# DROP_METHOD=threshold
# NPV discount rate (decimal, default: 0.10 = 10%).
# DROP_NPV_DISCOUNT_RATE=0.10
# NPV horizon in years (default: 5).
# DROP_NPV_HORIZON_YEARS=5

# --- Renewal Monitoring & Notifications ---
#
# Thresholds for renewal alert generation (defaults: 30 warning, 7 critical).
# RENEWAL_WARNING_DAYS=30
# RENEWAL_CRITICAL_DAYS=7

# Enable desktop notifications via notify-send (Linux/BSD only).
# NOTIFIER_DESKTOP_ENABLED=false

# Generic webhook URL for alert forwarding (Slack, Discord, etc.).
# NOTIFIER_WEBHOOK_URL=https://hooks.example.com/alert

# Telegram bot integration. Create a bot via @BotFather to get a token.
# NOTIFIER_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# NOTIFIER_TELEGRAM_CHAT_ID=-1001234567890

# --- Watchlist Polling ---
#
# Interval between watchlist polls in hours (default: 24).
# WATCHLIST_POLL_INTERVAL_HOURS=24
# Delay between RDAP requests per domain in ms (default: 1000).
# WATCHLIST_RDAP_DELAY_MS=1000

# --- Scheduler (in-process cron) ---
#
# Enable when the API server runs as a long-lived process.
# For one-shot execution (crontab compatible), use:
#   dominus scheduler run <job>
# SCHEDULER_ENABLED=false
# SCHEDULER_RENEWAL_CHECK_CRON=0 8 * * *
# SCHEDULER_RESCORE_CRON=0 9 * * 1
# SCHEDULER_PRUNE_CRON=0 10 1 * *
# SCHEDULER_WATCHLIST_CRON=0 7 * * *
# Scheduler warmup delay in ms (default: 5000).
# SCHEDULER_WARMUP_MS=5000

# --- Backup ---
#
# Directory for VACUUM INTO backups (default: ./data/backup).
# BACKUP_DIR=./data/backup
# Retention in days (default: 30).
# BACKUP_RETENTION_DAYS=30
# Backup cron expression (default: 0 4 * * * = daily at 04:00).
# SCHEDULER_BACKUP_CRON=0 4 * * *

# --- Auto Weight Tuning ---
#
# When enabled, the system periodically runs backtest → suggest → validate
# → apply cycle on scoring weights. Safety guardrails prevent runaway drift.
# Start with AUTO_TUNE_DRY_RUN=true to preview changes before live tuning.
# AUTO_TUNE_ENABLED=false
# AUTO_TUNE_WEIGHTS_PATH=./data/weights-override.json
# AUTO_TUNE_MIN_SAMPLE=20
# AUTO_TUNE_MAX_DELTA=0.05
# AUTO_TUNE_MAX_DRIFT=0.20
# AUTO_TUNE_DRY_RUN=true
# AUTO_TUNE_CRON=0 6 1 * *

# --- API Authentication ---
#
# Comma-separated API keys for REST API authentication.
# When empty or unset, authentication is disabled (not recommended for
# production deployments). Supports named keys with name=key format:
#   API_KEYS=sk-my-secret
#   API_KEYS=admin=sk-admin-key,readonly=sk-readonly-key
#
# For production, prefer FILE_API_KEYS to avoid exposing keys in process
# listings (/proc/self/environ). FILE_API_KEYS takes precedence.
# File format: one key per line, supports # comments and name=key format.
# File should have permissions 0600.
#   FILE_API_KEYS=/etc/dominus/api-keys.conf
#
# Clients authenticate via Authorization: Bearer <key> header.
# The /api/health endpoint is always accessible without auth.
# API_KEYS=

# --- Registrar Providers ---
#
# Default registrar provider for purchases (default: manual).
# Options: manual, cloudflare, namecheap, godaddy, porkbun, namesilo, dynadot.
# When set to manual, all purchase operations return failure (safe default).
# REGISTRAR_PROVIDER=manual
#
# Purchase auto-approval mode: never | under-buy-max | always (default: never).
# Recommended: start with 'never', switch to 'under-buy-max' after testing.
# PURCHASE_AUTO_APPROVAL=never
#
# File-based registrar config (secure alternative to env vars).
# Format: one provider per section with [provider_name] header.
# Takes precedence over individual env vars for security.
# FILE_REGISTRAR_CONFIG=/etc/dominus/registrar.conf
#
# --- Cloudflare Registrar ---
# API token with Zone:Read, Registrar:Read, and Registrar:Write permissions.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=
# Cloudflare Account ID (found in the dashboard overview page).
# CLOUDFLARE_ACCOUNT_ID=
#
# --- Namecheap Registrar ---
# API key, username, and whitelisted client IP (all required).
# REGISTRAR_NAMECHEAP_API_KEY=
# REGISTRAR_NAMECHEAP_USERNAME=
# REGISTRAR_NAMECHEAP_CLIENT_IP=
#
# --- GoDaddy Registrar ---
# API key and secret from developer.godaddy.com.
# REGISTRAR_GODADDY_API_KEY=
# REGISTRAR_GODADDY_API_SECRET=
#
# --- Porkbun Registrar ---
# API key and secret API key from porkbun.com/account/api.
# REGISTRAR_PORKBUN_API_KEY=
# REGISTRAR_PORKBUN_SECRET_API_KEY=
#
# --- NameSilo Registrar ---
# API key from namesilo.com/account/api.
# REGISTRAR_NAMESILO_API_KEY=
#
# --- Dynadot Registrar ---
# API key from dynadot.com/account/api.
# REGISTRAR_DYNADOT_API_KEY=
