{
  "name": "dominus",
  "version": "0.2.0",
  "description": "Decision-support engine for buying and reselling DNS domains on the aftermarket",
  "private": false,
  "license": "MIT",
  "author": "AlessioBrillo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlessioBrillo/dominus.git"
  },
  "bugs": {
    "url": "https://github.com/AlessioBrillo/dominus/issues"
  },
  "homepage": "https://github.com/AlessioBrillo/dominus#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dominus": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('coverage',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dns",
    "domain",
    "investment",
    "domaining",
    "scoring",
    "aftermarket"
  ],
  "dependencies": {
    "@types/cors": "^2.8.19",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "psl": "^1.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "@types/psl": "1.1.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
