{
  "name": "dominus",
  "version": "0.10.0-dev",
  "description": "Open-source decision-support engine for buying, reselling, and managing DNS domain portfolios — self-hosted community edition or managed DOMINUS Cloud",
  "private": false,
  "license": "AGPL-3.0-only",
  "author": "AlessioBrillo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlessioBrillo/dominus.git"
  },
  "bugs": {
    "url": "https://github.com/AlessioBrillo/dominus/issues"
  },
  "homepage": "https://github.com/AlessioBrillo/dominus#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/AlessioBrillo"
  },
  "contributors": [
    "AlessioBrillo"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dominus": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --reporter=verbose src/db/provider/postgres-adapter.test.ts",
    "bench": "vitest bench --reporter=default",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "audit": "npm audit --audit-level=high",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:dry": "standard-version --dry-run",
    "prepush": "npm run typecheck && npm run lint && npm test && cd frontend && npm run typecheck && npm run lint && npm test && cd ..",
    "prepush:local": "npm run typecheck && npm run lint && npm test && cd frontend && npm run typecheck && npm run lint && npm test && cd ..",
    "ci:backend": "npm run typecheck && npm run build && npm run db:sync:check && npm run lint && npm run format:check && npm test -- --coverage",
    "ci:frontend": "cd frontend && npm run typecheck && npm run lint && npm run test && npm run build",
    "ci:local": "npm run typecheck && npm run build && npm run db:sync:check && npm test",
    "ci:local:frontend": "cd frontend && npm run typecheck && npm run test && npm run build",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('coverage',{recursive:true,force:true})\"",
    "db:sync:check": "tsx src/db/validate-migration-sync.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --config frontend/eslint.config.js"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "frontend/dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "keywords": [
    "dns",
    "domain",
    "investment",
    "domaining",
    "scoring",
    "aftermarket",
    "open-source",
    "saas",
    "portfolio",
    "trademark",
    "agpl"
  ],
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "node-cron": "^4.6.0",
    "node-notifier": "^10.0.1",
    "pino": "^10.3.1",
    "psl": "^1.15.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "pg": "^8.15.6",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/pg": "^8.11.14",
    "@types/psl": "1.1.3",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "standard-version": "^9.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
