{
  "name": "dominus",
  "version": "0.1.0",
  "description": "Decision-support engine for buying and reselling DNS domains on the aftermarket",
  "private": false,
  "license": "MIT",
  "author": "AlessioBrillo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlessioBrillo/dominus.git"
  },
  "bugs": {
    "url": "https://github.com/AlessioBrillo/dominus/issues"
  },
  "homepage": "https://github.com/AlessioBrillo/dominus#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dominus": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist/ coverage/"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dns",
    "domain",
    "investment",
    "domaining",
    "scoring",
    "aftermarket"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.21.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
